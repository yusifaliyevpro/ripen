{
  "name": "ripencli",
  "version": "1.2.5",
  "description": "Interactive dependency updater for npm, pnpm, yarn, and bun",
  "license": "MIT",
  "author": {
    "name": "Yusif Aliyev",
    "email": "yusifaliyevpro@gmail.com",
    "url": "https://yusifaliyevpro.com"
  },
  "funding": [
    {
      "type": "patreon",
      "url": "https://patreon.com/yusifaliyevpro"
    },
    {
      "type": "kofe.al",
      "url": "https://kofe.al/@yusifaliyevpro"
    }
  ],
  "homepage": "https://ripencli.vercel.app",
  "bugs": {
    "url": "https://github.com/yusifaliyevpro/ripen/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yusifaliyevpro/ripen.git"
  },
  "type": "module",
  "bin": {
    "ripen": "dist/cli.js"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsx src/cli.tsx",
    "typecheck": "tsc --noEmit",
    "start": "node dist/cli.js",
    "check": "node --no-warnings scripts/pr-checks.ts",
    "docs:dev": "pnpm --prefix docs dev",
    "docs:build": "pnpm --prefix docs build",
    "docs:start": "pnpm --prefix docs start"
  },
  "keywords": [
    "npm",
    "pnpm",
    "yarn",
    "bun",
    "dependencies",
    "outdated",
    "update",
    "upgrade",
    "updater",
    "package-manager",
    "interactive",
    "cli",
    "tui"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "execa": "9.6.1",
    "ink": "7.1.0",
    "ink-scroll-view": "0.3.7",
    "react": "19.2.7"
  },
  "devDependencies": {
    "@types/node": "24.12.2",
    "@types/react": "19.2.17",
    "prettier": "3.9.4",
    "tsdown": "0.22.4",
    "typescript": "7.0.2"
  }
}
